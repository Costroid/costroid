# Address the Costroid server listens on (host:port). The `--addr` flag
# overrides this. Default: :8080
COSTROID_ADDR=:8080

# Directory holding the embedded data store (created if missing). The
# store is single-process: stop `costroid serve` before `costroid ingest`.
# Default: ./data
COSTROID_DATA_DIR=./data

# Path to the strict scheduled-ingestion sources JSON file. `costroid serve
# --sync` reads this path; the `--sources` flag overrides it. This value is a
# path only, never credential material.
COSTROID_SOURCES=./sources.json
